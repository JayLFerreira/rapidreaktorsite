<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rapid Reaktor — Millisecond Response to Security Threats</title>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,1,0" rel="stylesheet">
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg:           #080c10;
            --bg-2:         #0c1118;
            --bg-3:         #101820;
            --border:       rgba(0, 220, 255, 0.14);
            --border-sub:   rgba(255, 255, 255, 0.06);
            --accent:       #00dcff;
            --accent-dim:   rgba(0, 220, 255, 0.08);
            --accent-glow:  rgba(0, 220, 255, 0.28);
            --green:        #00d97e;
            --green-dim:    rgba(0, 217, 126, 0.1);
            --text:         #bdc9d7;
            --text-dim:     #566374;
            --text-bright:  #eef2f6;
            --font-display: 'Rajdhani', sans-serif;
            --font-body:    'Inter', sans-serif;
            --font-mono:    'JetBrains Mono', monospace;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: var(--font-body);
            background-color: var(--bg);
            color: var(--text);
            line-height: 1.6;
            overflow-x: hidden;
            background-image: radial-gradient(circle, rgba(0, 220, 255, 0.032) 1px, transparent 1px);
            background-size: 28px 28px;
        }

        /* Scanlines */
        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 3px,
                rgba(0, 0, 0, 0.012) 3px,
                rgba(0, 0, 0, 0.012) 4px
            );
            pointer-events: none;
            z-index: 9999;
        }

        /* ─── NAV ─── */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(8, 12, 16, 0.88);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-bottom: 1px solid var(--border-sub);
            z-index: 1000;
        }

        .nav-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
        }

        .logo img {
            height: 44px;
            width: auto;
            object-fit: contain;
            filter: drop-shadow(0 0 8px rgba(0, 220, 255, 0.3));
        }

        .logo-text {
            font-family: var(--font-mono);
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-bright);
            letter-spacing: 0.03em;
        }

        .logo-text .u { color: var(--accent); }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 2.5rem;
        }

        .nav-links a {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-dim);
            text-decoration: none;
            letter-spacing: 0.02em;
            transition: color 0.2s;
        }

        .nav-links a:hover { color: var(--accent); }

        /* ─── CONTAINER ─── */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* ─── HERO ─── */
        .hero-bg { background: var(--bg-2); }

        .hero {
            padding: 9rem 2rem 5rem;
            text-align: center;
            max-width: 1200px;
            margin: 0 auto;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-family: var(--font-mono);
            font-size: 0.7rem;
            color: var(--accent);
            letter-spacing: 0.12em;
            text-transform: uppercase;
            border: 1px solid var(--border);
            background: var(--accent-dim);
            padding: 0.35rem 0.9rem;
            border-radius: 2px;
            margin-bottom: 2.25rem;
        }

        .eyebrow-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--accent);
            box-shadow: 0 0 6px var(--accent);
            animation: blink 2s ease-in-out infinite;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0.35; }
        }

        .hero-title {
            font-family: var(--font-display);
            font-size: clamp(3.25rem, 7.5vw, 5.75rem);
            font-weight: 700;
            line-height: 0.92;
            color: var(--text-bright);
            letter-spacing: -0.01em;
            margin-bottom: 1.75rem;
        }

        .hero-title .glow-line {
            display: block;
            background: linear-gradient(100deg, var(--accent) 10%, #00ff99 90%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-sub {
            font-size: 1.05rem;
            color: var(--text-dim);
            max-width: 540px;
            margin: 0 auto 3rem;
            line-height: 1.75;
        }

        /* ─── DASHBOARD ─── */
        .dashboard-wrap {
            max-width: 900px;
            margin: 0 auto 2.5rem;
        }

        .dashboard-card {
            background: var(--bg-2);
            border: 1px solid var(--border-sub);
            border-radius: 12px;
            padding: 1.75rem;
            position: relative;
            overflow: hidden;
            box-shadow:
                0 0 0 1px rgba(0,220,255,0.04),
                0 48px 96px rgba(0,0,0,0.55),
                inset 0 1px 0 rgba(255,255,255,0.04);
        }

        .dashboard-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent 0%, var(--accent) 50%, transparent 100%);
            opacity: 0.5;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            margin-bottom: 1.25rem;
        }

        .stat-card {
            background: rgba(0, 220, 255, 0.04);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 1.25rem 1rem;
            text-align: center;
            transition: border-color 0.2s, background 0.2s;
        }

        .stat-card:hover {
            border-color: rgba(0, 220, 255, 0.35);
            background: rgba(0, 220, 255, 0.07);
        }

        .stat-num {
            font-family: var(--font-display);
            font-size: 2.25rem;
            font-weight: 700;
            color: var(--accent);
            text-shadow: 0 0 18px var(--accent-glow);
            line-height: 1;
            margin-bottom: 0.4rem;
            transition: transform 0.2s ease;
        }

        .stat-label {
            font-family: var(--font-mono);
            font-size: 0.65rem;
            font-weight: 500;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        /* ─── ACTIVITY FEED ─── */
        .activity-feed {
            background: rgba(4, 8, 12, 0.7);
            border: 1px solid var(--border-sub);
            border-radius: 6px;
            padding: 1rem 1rem 0.625rem;
            min-height: 185px;
            max-height: 185px;
            overflow: hidden;
        }

        .feed-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-family: var(--font-mono);
            font-size: 0.65rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 0.75rem;
            padding-bottom: 0.625rem;
            border-bottom: 1px solid var(--border-sub);
        }

        .feed-header::before {
            content: '$';
            color: var(--accent);
            opacity: 0.8;
        }

        .feed-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 4px var(--green);
            margin-left: auto;
            animation: blink 1.5s ease-in-out infinite;
        }

        .activity-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.45rem 0.625rem;
            background: rgba(255, 255, 255, 0.015);
            border: 1px solid rgba(255,255,255,0.04);
            border-radius: 4px;
            margin-bottom: 0.375rem;
            font-family: var(--font-mono);
            font-size: 0.78rem;
            color: var(--text);
            opacity: 0;
            animation: slideIn 0.35s forwards;
        }

        .activity-item:nth-child(2) { animation-delay: 0.05s; }
        .activity-item:nth-child(3) { animation-delay: 0.12s; }
        .activity-item:nth-child(4) { animation-delay: 0.2s;  }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-10px); }
            to   { opacity: 1; transform: translateX(0);     }
        }

        @keyframes slideOut {
            from { opacity: 1; transform: translateX(0);    }
            to   { opacity: 0; transform: translateX(10px); }
        }

        .activity-prefix { color: var(--text-dim); margin-right: 0.3rem; }

        .activity-ip {
            color: var(--accent);
            text-shadow: 0 0 8px rgba(0,220,255,0.35);
            font-weight: 600;
        }

        .activity-list { color: var(--text-dim); }

        .activity-time {
            font-size: 0.68rem;
            color: var(--text-dim);
            flex-shrink: 0;
            margin-left: 1rem;
        }

        /* ─── CTA ─── */
        .cta-wrap { text-align: center; margin-top: 2rem; }

        .cta-button {
            display: inline-flex;
            align-items: center;
            gap: 0.625rem;
            font-family: var(--font-mono);
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #060a0e;
            background: var(--accent);
            border: none;
            padding: 0.9rem 2.25rem;
            border-radius: 3px;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.15s, box-shadow 0.2s;
            box-shadow: 0 0 20px rgba(0,220,255,0.18);
        }

        .cta-button::after {
            content: '→';
            transition: transform 0.2s;
        }

        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 36px rgba(0,220,255,0.48), 0 8px 24px rgba(0,0,0,0.3);
        }

        .cta-button:hover::after { transform: translateX(3px); }
        .cta-button:active { transform: translateY(0); }

        /* ─── SECTION COMMONS ─── */
        .section { padding: 6rem 2rem; }

        .section-label {
            font-family: var(--font-mono);
            font-size: 0.68rem;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 0.14em;
            margin-bottom: 0.6rem;
        }

        .section-title {
            font-family: var(--font-display);
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 700;
            color: var(--text-bright);
            line-height: 1;
            letter-spacing: -0.01em;
            margin-bottom: 0.875rem;
        }

        .section-sub {
            font-size: 1rem;
            color: var(--text-dim);
            line-height: 1.75;
        }

        /* ─── HOW IT WORKS ─── */
        .how-section {
            background: var(--bg);
            border-top: 1px solid var(--border-sub);
            border-bottom: 1px solid var(--border-sub);
            position: relative;
            overflow: hidden;
            padding-bottom: 3rem;
        }

        .how-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .how-arch-label {
            font-family: 'Space Grotesk', var(--font-display);
            font-size: 0.7rem;
            letter-spacing: 0.4em;
            color: #00e2ee;
            text-transform: uppercase;
            opacity: 0.8;
            margin-bottom: 1rem;
            display: block;
        }

        .how-main-title {
            font-family: 'Space Grotesk', var(--font-display);
            font-size: clamp(2.5rem, 7vw, 4.5rem);
            font-weight: 700;
            letter-spacing: -0.04em;
            text-shadow: 0 0 15px rgba(0, 242, 255, 0.5);
            color: var(--text-bright);
            margin-bottom: 1.5rem;
            line-height: 1;
        }

        .how-main-sub {
            max-width: 42rem;
            margin: 0 auto;
            color: #a6acb3;
            font-size: 1rem;
            line-height: 1.75;
            font-weight: 300;
        }

        .how-kinetic-flow {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            position: relative;
            margin-bottom: 5rem;
        }

        @media (min-width: 1024px) {
            .how-kinetic-flow { flex-direction: row; align-items: stretch; }
        }

        .kinetic-connector {
            display: none;
        }

        @media (min-width: 1024px) {
            .kinetic-connector {
                display: block;
                position: absolute;
                top: 50%;
                left: 25%;
                right: 25%;
                height: 2px;
                background: linear-gradient(90deg, transparent, #00f2ff, transparent);
                opacity: 0.3;
                transform: translateY(-50%);
                pointer-events: none;
                z-index: 0;
            }
        }

        .glass-card {
            background: rgba(30, 39, 46, 0.4);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(0, 242, 255, 0.15);
            box-shadow: inset 0 0 20px rgba(0, 242, 255, 0.05);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 0.75rem;
            padding: 2rem;
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            flex: 1;
            z-index: 1;
        }

        .glass-card:hover {
            border-color: rgba(0, 242, 255, 0.4);
            box-shadow: 0 0 30px rgba(0, 242, 255, 0.1), inset 0 0 25px rgba(0, 242, 255, 0.1);
            transform: translateY(-4px);
        }

        .glass-card--core {
            border-color: rgba(0, 241, 254, 0.3);
            background: rgba(30, 39, 46, 0.6);
            transform: scale(1.05);
            z-index: 2;
        }

        .glass-card--core:hover { transform: scale(1.05) translateY(-4px); }

        .how-step-num { display: none; }

        .how-icon-box {
            width: 64px;
            height: 64px;
            border-radius: 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: box-shadow 0.3s;
        }

        .how-icon-box--detect {
            background: rgba(159, 5, 25, 0.2);
            border: 1px solid rgba(215, 56, 59, 0.3);
            box-shadow: 0 0 20px rgba(215, 56, 59, 0.2);
        }

        .glass-card:hover .how-icon-box--detect { box-shadow: 0 0 30px rgba(215, 56, 59, 0.4); }

        .how-icon-box--process {
            background: rgba(0, 241, 254, 0.1);
            border: 1px solid rgba(0, 226, 238, 0.3);
            box-shadow: 0 0 20px rgba(0, 241, 254, 0.2);
        }

        .glass-card:hover .how-icon-box--process { box-shadow: 0 0 30px rgba(0, 241, 254, 0.4); }

        .how-icon-box--block {
            background: rgba(0, 104, 119, 0.2);
            border: 1px solid rgba(0, 224, 254, 0.3);
            box-shadow: 0 0 20px rgba(0, 224, 254, 0.2);
        }

        .glass-card:hover .how-icon-box--block { box-shadow: 0 0 30px rgba(0, 224, 254, 0.4); }

        .how-card-title {
            font-family: 'Space Grotesk', var(--font-display);
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-bright);
            text-transform: uppercase;
            letter-spacing: -0.02em;
            margin-bottom: 0.25rem;
        }

        .how-card-source {
            font-family: var(--font-mono);
            font-size: 0.7rem;
            font-weight: 500;
            color: #00e2ee;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            margin-bottom: 1rem;
        }

        .how-card-desc {
            color: #a6acb3;
            line-height: 1.65;
            margin-bottom: 2rem;
            font-size: 0.9rem;
        }

        .how-flow-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-family: var(--font-mono);
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #99f7ff;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
            transition: gap 0.2s;
        }

        .how-flow-btn:hover { gap: 0.85rem; }

        .how-flow-btn--muted { color: #a6acb3; font-size: 0.65rem; }
        .how-flow-btn--muted:hover { color: var(--text-bright); }

        .how-flow-btns { display: flex; gap: 1.5rem; }

        .how-viz {
            width: 100%;
            max-width: 56rem;
            margin: 0 auto;
            height: 16rem;
            border-radius: 1rem;
            background: var(--bg-3);
            overflow: hidden;
            position: relative;
            border: 1px solid rgba(67, 73, 79, 0.1);
        }

        .how-viz-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, var(--bg-3) 0%, transparent 60%);
        }

        .how-viz-terminal {
            position: absolute;
            bottom: 1.5rem;
            left: 2rem;
        }

        .how-viz-pulse {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.5rem;
        }

        .how-viz-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #00f1fe;
            animation: blink 1.5s ease-in-out infinite;
        }

        .how-viz-label {
            font-family: var(--font-mono);
            font-size: 0.65rem;
            letter-spacing: 0.2em;
            color: var(--text-bright);
            text-transform: uppercase;
            opacity: 0.6;
        }

        .how-viz-log {
            font-family: var(--font-mono);
            font-size: 0.625rem;
            color: rgba(0, 226, 238, 0.6);
            line-height: 1.6;
        }

        .cta-outline {
            display: inline-block;
            font-family: var(--font-mono);
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--accent);
            border: 1px solid var(--accent);
            border-radius: 3px;
            padding: 0.75rem 1.5rem;
            text-decoration: none;
            text-align: center;
            transition: background 0.2s;
        }

        .cta-outline:hover { background: var(--accent-dim); }

        /* ─── LOGO SECTION ─── */
        .logo-section {
            padding: 4rem 2rem;
            text-align: center;
            background: var(--bg);
            border-top: 1px solid var(--border-sub);
            border-bottom: 1px solid var(--border-sub);
        }

        .logo-section img {
            max-width: 280px;
            width: 100%;
            height: auto;
            filter: drop-shadow(0 0 18px rgba(0, 220, 255, 0.35)) drop-shadow(0 0 40px rgba(0, 220, 255, 0.15));
        }

        /* ─── FEATURES ─── */
        .features-section { background: var(--bg-2); }

        .features-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .features-cap-label {
            font-family: var(--font-display);
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--accent);
            letter-spacing: 0.06em;
            text-transform: uppercase;
            margin-bottom: 0.75rem;
        }

        .features-title {
            font-family: var(--font-display);
            font-size: 2.8rem;
            font-weight: 700;
            color: var(--text-bright);
            text-transform: uppercase;
            letter-spacing: 0.04em;
            line-height: 1.1;
            margin-bottom: 1.25rem;
        }

        .features-title .hl {
            display: block;
            color: var(--accent);
            text-shadow: 0 0 28px var(--accent-glow), 0 0 60px rgba(0,220,255,0.15);
        }

        .features-sub {
            font-size: 0.95rem;
            color: var(--text-dim);
            max-width: 560px;
            margin: 0 auto;
            line-height: 1.7;
        }

        .feat-row-1 {
            display: grid;
            grid-template-columns: 3fr 2fr;
            gap: 1.25rem;
            margin-bottom: 1.25rem;
        }

        .feat-row-2 {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.25rem;
            margin-bottom: 1.25rem;
        }

        .feat-row-3 { margin-bottom: 1.25rem; }

        .feature-card {
            background: var(--bg-3);
            border: 1px solid var(--border-sub);
            border-radius: 8px;
            padding: 1.75rem;
            position: relative;
            transition: border-color 0.25s, transform 0.25s;
        }

        .feature-card:hover {
            border-color: var(--border);
            transform: translateY(-3px);
        }

        .feature-card--center { border-color: rgba(0, 220, 255, 0.2); }
        .feature-card--center:hover { border-color: var(--accent); }

        .feature-card--wide {
            display: flex;
            align-items: center;
            gap: 2rem;
        }

        .feature-card--wide:hover { transform: none; border-color: var(--border); }
        .feature-card--wide .feature-body { flex: 1; }

        .feature-icon {
            width: 42px;
            height: 42px;
            background: var(--accent-dim);
            border: 1px solid var(--border);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent);
            margin-bottom: 1.375rem;
            flex-shrink: 0;
        }

        .feature-card--wide .feature-icon { margin-bottom: 0; }

        .feature-title {
            font-family: var(--font-display);
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-bright);
            margin-bottom: 0.625rem;
        }

        .feature-desc {
            font-size: 0.875rem;
            color: var(--text-dim);
            line-height: 1.7;
        }

        .feature-tag {
            position: absolute;
            bottom: 1.75rem;
            right: 1.75rem;
            font-family: var(--font-mono);
            font-size: 0.58rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--accent);
            opacity: 0.55;
        }

        /* ─── INTEGRATED SECTION ─── */
        .integrated-section {
            background: var(--bg-3);
            border: 1px solid var(--border-sub);
            border-radius: 8px;
            padding: 3rem;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: center;
        }

        .integrated-title {
            font-family: var(--font-display);
            font-size: 2.2rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            line-height: 1.1;
            color: var(--text-bright);
            margin-bottom: 1.75rem;
        }

        .integrated-title .hl {
            display: block;
            color: var(--accent);
            text-shadow: 0 0 24px var(--accent-glow);
        }

        .integrated-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .integrated-list li {
            font-size: 0.9rem;
            color: var(--text-dim);
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            line-height: 1.55;
        }

        .integrated-list li::before {
            content: '●';
            color: var(--accent);
            font-size: 0.4rem;
            margin-top: 0.5rem;
            flex-shrink: 0;
        }

        .integrated-video {
            background: var(--bg-2);
            border: 1px solid var(--border-sub);
            border-radius: 6px;
            aspect-ratio: 16/9;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .integrated-play {
            width: 52px;
            height: 52px;
            background: rgba(0, 220, 255, 0.1);
            border: 1px solid var(--border);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent);
            cursor: pointer;
            transition: background 0.2s;
        }

        .integrated-play:hover { background: rgba(0, 220, 255, 0.2); }

        /* ─── MODAL ─── */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.82);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }

        .modal-overlay.active { display: flex; }

        .modal-box {
            background: var(--bg-2);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 2.5rem;
            max-width: 460px;
            width: 90%;
            position: relative;
            box-shadow:
                0 0 48px rgba(0,220,255,0.1),
                0 48px 96px rgba(0,0,0,0.65);
            animation: modalIn 0.28s ease;
        }

        @keyframes modalIn {
            from { opacity: 0; transform: translateY(18px) scale(0.975); }
            to   { opacity: 1; transform: translateY(0) scale(1);        }
        }

        .modal-box::before {
            content: '';
            position: absolute;
            top: 0; left: 2rem; right: 2rem;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            opacity: 0.55;
        }

        .modal-close {
            position: absolute;
            top: 1rem; right: 1rem;
            background: none;
            border: 1px solid var(--border-sub);
            color: var(--text-dim);
            width: 30px; height: 30px;
            border-radius: 4px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            line-height: 1;
            transition: border-color 0.2s, color 0.2s;
        }

        .modal-close:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .modal-title {
            font-family: var(--font-display);
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text-bright);
            margin-bottom: 0.375rem;
        }

        .modal-sub {
            font-size: 0.875rem;
            color: var(--text-dim);
            margin-bottom: 2rem;
        }

        .form-group { margin-bottom: 1.25rem; }

        .form-label {
            display: block;
            font-family: var(--font-mono);
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-dim);
            margin-bottom: 0.5rem;
        }

        .form-input {
            width: 100%;
            background: var(--bg);
            border: 1px solid var(--border-sub);
            border-radius: 4px;
            color: var(--text-bright);
            font-family: var(--font-body);
            font-size: 0.95rem;
            padding: 0.75rem 1rem;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-input::placeholder { color: var(--text-dim); opacity: 0.6; }

        .form-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(0,220,255,0.06);
        }

        .form-submit {
            width: 100%;
            padding: 0.875rem;
            background: var(--accent);
            color: #060a0e;
            border: none;
            border-radius: 3px;
            font-family: var(--font-mono);
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            cursor: pointer;
            margin-top: 0.5rem;
            transition: box-shadow 0.2s, transform 0.15s;
        }

        .form-submit:hover {
            box-shadow: 0 0 22px rgba(0,220,255,0.4);
            transform: translateY(-1px);
        }

        .form-success {
            display: none;
            text-align: center;
            padding: 2.5rem 1rem;
        }

        .form-success.active { display: block; }

        .success-icon { font-size: 2.5rem; margin-bottom: 1rem; }

        .success-title {
            font-family: var(--font-display);
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--green);
            margin-bottom: 0.5rem;
        }

        .success-msg { font-size: 0.875rem; color: var(--text-dim); }

        /* ─── FOOTER ─── */
        footer {
            background: var(--bg);
            border-top: 1px solid var(--border-sub);
            padding: 2.5rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .footer-logo {
            font-family: var(--font-display);
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-bright);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 0.4rem;
        }

        .footer-copy {
            font-family: var(--font-mono);
            font-size: 0.62rem;
            color: var(--text-dim);
            opacity: 0.45;
            letter-spacing: 0.04em;
        }

        .footer-links {
            display: flex;
            gap: 2rem;
        }

        .footer-links a {
            font-family: var(--font-mono);
            font-size: 0.62rem;
            color: var(--text-dim);
            text-decoration: none;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            transition: color 0.2s;
        }

        .footer-links a:hover { color: var(--accent); }

        /* ─── RESPONSIVE ─── */
        @media (max-width: 768px) {
            .stats-grid  { grid-template-columns: repeat(2, 1fr); }
            .flow-row    { flex-direction: column; }
            .flow-conn   { display: none; }
            .flow-cta    { flex-direction: column; gap: 1.5rem; }
            .footer      { flex-direction: column; gap: 1.5rem; align-items: flex-start; }
            .footer-links { flex-wrap: wrap; gap: 1rem; }
            .nav-links   { display: none; }
            .hero-title  { font-size: 3rem; }
            .hero        { padding: 7rem 1.5rem 4rem; }
            .feat-row-1, .feat-row-2 { grid-template-columns: 1fr; }
            .feature-card--wide { flex-direction: column; align-items: flex-start; }
            .integrated-section { grid-template-columns: 1fr; }
            .features-title { font-size: 2rem; }
        }
    </style>
</head>
