<script>
    // ─── LIVE ACTIVITY ANIMATION ───
    document.addEventListener('DOMContentLoaded', function () {
        const feed      = document.getElementById('activityFeed');
        const recentEl  = document.getElementById('recentActions');
        const totalEl   = document.getElementById('totalActions');

        if (!feed || !recentEl || !totalEl) return;

        const threats = [
            { ip: '45.76.112.34',   list: 'ssh-blocklist' },
            { ip: '91.134.22.187',  list: 'brute-force'   },
            { ip: '185.220.101.53', list: 'vpn-threats'   },
            { ip: '77.88.55.241',   list: 'ssh-blocklist' },
            { ip: '104.21.34.89',   list: 'brute-force'   },
            { ip: '162.55.18.247',  list: 'vpn-threats'   },
            { ip: '51.89.153.112',  list: 'ssh-blocklist' },
            { ip: '138.68.72.196',  list: 'brute-force'   },
            { ip: '95.216.44.178',  list: 'vpn-threats'   },
            { ip: '167.71.98.63',   list: 'ssh-blocklist' },
        ];

        let currentCount = 92;
        let totalCount   = 1847;
        let threatIndex  = 0;

        function addThreat() {
            const threat = threats[threatIndex % threats.length];
            threatIndex++;
            currentCount++;
            totalCount++;

            recentEl.style.transform = 'scale(1.12)';
            recentEl.textContent = currentCount;
            totalEl.style.transform = 'scale(1.12)';
            totalEl.textContent = totalCount.toLocaleString();

            setTimeout(() => {
                recentEl.style.transform = 'scale(1)';
                totalEl.style.transform  = 'scale(1)';
            }, 200);

            const item = document.createElement('div');
            item.className = 'activity-item';
            item.style.animation = 'none';
            item.innerHTML = `
                <span><span class="activity-prefix">+</span> added <span class="activity-ip">${threat.ip}</span> <span class="activity-list">→ ${threat.list}</span></span>
                <span class="activity-time">just now</span>
            `;

            const header = feed.querySelector('.feed-header');
            if (header && header.nextSibling) {
                feed.insertBefore(item, header.nextSibling);
            } else {
                feed.appendChild(item);
            }

            requestAnimationFrame(() => {
                item.style.animation = 'slideIn 0.35s forwards';
            });

            const items = feed.querySelectorAll('.activity-item');
            if (items.length > 3) {
                const last = items[items.length - 1];
                last.style.animation = 'slideOut 0.3s forwards';
                setTimeout(() => last.remove(), 300);
            }

            updateTimestamps();
        }

        function updateTimestamps() {
            const items = feed.querySelectorAll('.activity-item');
            const times = ['just now', '2s ago', '5s ago'];
            items.forEach((item, i) => {
                const t = item.querySelector('.activity-time');
                if (t && times[i]) t.textContent = times[i];
            });
        }

        function startLoop() {
            let count = 0;
            const timings = [2000, 2000, 2000, 500, 500, 500, 500, 500, 500, 500];

            function next() {
                if (count < 10) {
                    addThreat();
                    count++;
                    setTimeout(next, timings[count] || 500);
                } else {
                    setTimeout(() => {
                        currentCount = 92;
                        totalCount   = 1847;
                        threatIndex  = 0;
                        recentEl.textContent = currentCount;
                        totalEl.textContent  = totalCount.toLocaleString();
                        startLoop();
                    }, 3000);
                }
            }
            next();
        }

        setTimeout(startLoop, 1000);
    });

    // ─── MODAL ───
    function openModal() {
        document.getElementById('contactModal').classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function closeModal() {
        document.getElementById('contactModal').classList.remove('active');
        document.body.style.overflow = '';
        setTimeout(() => {
            document.getElementById('formContainer').style.display = 'block';
            document.getElementById('successMessage').classList.remove('active');
            document.getElementById('contactForm').reset();
        }, 300);
    }

    document.getElementById('contactModal').addEventListener('click', function (e) {
        if (e.target === this) closeModal();
    });

    document.getElementById('contactForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        try {
            const res = await fetch(e.target.action, {
                method: 'POST',
                body: new FormData(e.target),
                headers: { 'Accept': 'application/json' }
            });
            if (res.ok) {
                document.getElementById('formContainer').style.display = 'none';
                document.getElementById('successMessage').classList.add('active');
                setTimeout(closeModal, 3000);
            } else {
                alert('Oops! There was a problem submitting your form. Please try again.');
            }
        } catch {
            alert('Oops! There was a problem submitting your form. Please try again.');
        }
    });
</script>

</body>
</html>
